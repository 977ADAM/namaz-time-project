APP_NAME=Namaz Time API
APP_VERSION=0.2.0
APP_ENV=development
APP_DEBUG=false
LOG_LEVEL=INFO

PRAYER_API_BASE_URL=https://api.aladhan.com/v1/timings
PRAYER_API_TIMEOUT_SECONDS=15
CACHE_TTL_SECONDS=300
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
SECURITY_HEADERS_ENABLED=true
METRICS_ENABLED=false
CORS_ALLOW_ORIGINS=*

HOST=127.0.0.1
PORT=8080
UVICORN_WORKERS=1
